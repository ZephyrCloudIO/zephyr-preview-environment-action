{
  "name": "zephyr-preview-environments-action",
  "version": "0.1.1",
  "description": "Create preview environments using Zephyr (PR-only action)",
  "main": "index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --minify --outfile=index.js",
    "build:examples": "cd zephyr-examples/jarvis && pnpm i && pnpm run build && cd ../hal && pnpm i && pnpm run build",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "ZephyrCloudIO",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "zephyr-agent": "^0.1.10"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@types/node": "24.10.4",
    "esbuild": "0.27.2",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "typescript": "5.9.3",
    "ultracite": "7.1.1"
  },
  "pnpm": {
    "overrides": {
      "qs": ">=6.14.1",
      "form-data": ">=4.0.4",
      "axios": "1.15.0",
      "undici": "6.24.0",
      "@isaacs/brace-expansion": ">=5.0.1",
      "@eslint/plugin-kit": "^0.5.0",
      "koa": "3.1.2",
      "picomatch": "^4.0.4"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm exec ultracite fix"
    ]
  }
}
